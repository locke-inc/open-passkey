<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <TargetFramework>net10.0</TargetFramework>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>
    <RootNamespace>OpenPasskey.Core</RootNamespace>
    <PackageId>OpenPasskey.Core</PackageId>
    <Version>0.1.3</Version>
    <Description>Core WebAuthn/FIDO2 protocol verification library with post-quantum support (ES256, ML-DSA-65, ML-DSA-65-ES256)</Description>
    <Authors>Locke Identity Networks Inc.</Authors>
    <PackageLicenseExpression>MIT</PackageLicenseExpression>
    <RepositoryUrl>https://github.com/locke-inc/open-passkey</RepositoryUrl>
    <RepositoryType>git</RepositoryType>
    <PackageTags>passkey;webauthn;fido2;post-quantum;mldsa</PackageTags>
    <PackageReadmeFile>README.md</PackageReadmeFile>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="PeterO.Cbor" Version="4.5.5" />
    <PackageReference Include="BouncyCastle.Cryptography" Version="2.6.2" />
  </ItemGroup>

  <ItemGroup>
    <Compile Remove="Tests/**" />
  </ItemGroup>

</Project>
