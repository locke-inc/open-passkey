{
  "name": "@open-passkey/sdk",
  "version": "0.1.2",
  "description": "Framework-agnostic browser SDK for passkey/WebAuthn authentication",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc && esbuild src/index.ts --bundle --format=iife --global-name=OpenPasskey --outfile=dist/open-passkey.iife.js --target=es2022 --minify",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "keywords": [
    "passkey",
    "webauthn",
    "fido2",
    "browser",
    "sdk"
  ],
  "author": "Locke Identity Networks Inc.",
  "license": "MIT",
  "type": "module",
  "devDependencies": {
    "esbuild": "^0.27.7",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18"
  }
}
