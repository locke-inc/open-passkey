{
    "name": "open-passkey/laravel",
    "description": "Laravel service provider for open-passkey WebAuthn/FIDO2 authentication",
    "license": "MIT",
    "type": "library",
    "require": {
        "php": ">=8.1",
        "open-passkey/server": "*",
        "illuminate/support": "^10.0|^11.0|^12.0",
        "illuminate/routing": "^10.0|^11.0|^12.0",
        "illuminate/http": "^10.0|^11.0|^12.0"
    },
    "autoload": {
        "psr-4": {
            "OpenPasskey\\Laravel\\": "src/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "OpenPasskey\\Laravel\\PasskeyServiceProvider"
            ]
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true,
    "repositories": [
        {
            "type": "path",
            "url": "../core-php"
        },
        {
            "type": "path",
            "url": "../server-php"
        }
    ]
}
