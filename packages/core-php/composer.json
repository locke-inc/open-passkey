{
    "name": "open-passkey/core",
    "description": "WebAuthn/FIDO2 core protocol verification library with post-quantum support",
    "type": "library",
    "license": "MIT",
    "keywords": ["passkey", "webauthn", "fido2", "post-quantum", "mldsa"],
    "homepage": "https://github.com/locke-inc/open-passkey",
    "require": {
        "php": ">=8.1",
        "ext-openssl": "*",
        "ext-json": "*"
    },
    "require-dev": {
        "phpunit/phpunit": "^11.0"
    },
    "suggest": {
        "ext-ffi": "Required for ML-DSA-65 (post-quantum) signature verification via liboqs"
    },
    "autoload": {
        "psr-4": {
            "OpenPasskey\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "OpenPasskey\\Tests\\": "tests/"
        }
    }
}
