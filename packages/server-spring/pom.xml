<?xml version="1.0" encoding="UTF-8"?>
<project xmlns="http://maven.apache.org/POM/4.0.0"
         xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:schemaLocation="http://maven.apache.org/POM/4.0.0 https://maven.apache.org/xsd/maven-4.0.0.xsd">
    <modelVersion>4.0.0</modelVersion>

    <groupId>com.openpasskey</groupId>
    <artifactId>open-passkey-spring</artifactId>
    <version>0.1.0</version>
    <packaging>jar</packaging>

    <name>open-passkey-spring</name>
    <description>Spring Boot starter for open-passkey WebAuthn/FIDO2 authentication</description>
    <url>https://github.com/locke-inc/open-passkey</url>

    <licenses>
        <license>
            <name>MIT License</name>
            <url>https://opensource.org/licenses/MIT</url>
        </license>
    </licenses>

    <developers>
        <developer>
            <name>Locke Identity Networks Inc.</name>
            <url>https://lockeidentity.com</url>
        </developer>
    </developers>

    <scm>
        <url>https://github.com/locke-inc/open-passkey</url>
        <connection>scm:git:git://github.com/locke-inc/open-passkey.git</connection>
    </scm>

    <parent>
        <groupId>org.springframework.boot</groupId>
        <artifactId>spring-boot-starter-parent</artifactId>
        <version>3.3.0</version>
        <relativePath/>
    </parent>

    <properties>
        <java.version>17</java.version>
    </properties>

    <dependencies>
        <dependency>
            <groupId>org.springframework.boot</groupId>
            <artifactId>spring-boot-starter-web</artifactId>
        </dependency>
        <dependency>
            <groupId>com.openpasskey</groupId>
            <artifactId>core-java</artifactId>
            <version>0.1.3</version>
        </dependency>
        <dependency>
            <groupId>org.springframework.boot</groupId>
            <artifactId>spring-boot-starter-test</artifactId>
            <scope>test</scope>
        </dependency>
    </dependencies>
</project>
