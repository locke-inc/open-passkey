{
    "name": "open-passkey/symfony",
    "description": "Symfony bundle for open-passkey WebAuthn/FIDO2 authentication",
    "license": "MIT",
    "type": "symfony-bundle",
    "require": {
        "php": ">=8.1",
        "open-passkey/server": "*",
        "symfony/framework-bundle": "^6.4|^7.0",
        "symfony/http-kernel": "^6.4|^7.0"
    },
    "autoload": {
        "psr-4": {
            "OpenPasskey\\Symfony\\": "src/"
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true,
    "repositories": [
        { "type": "path", "url": "../core-php" },
        { "type": "path", "url": "../server-php" }
    ]
}
